{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cadence Lab",
  "version": "0.1.0",
  "identifier": "com.cadencelab.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cadence Lab",
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "category": "Productivity",
    "shortDescription": "AI-driven semantic video editor for YouTube creators",
    "longDescription": "Cadence Lab uses Claude Opus 4.7 to classify every pause and filler word in your video, then plans intelligent cuts you can review one-by-one with audio context before rendering.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
