# Copy this file to .env and fill in your keys. .env is gitignored.

# Groq API key — required for the default "groq" transcription backend (stage 2).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic API key — required for the pause/filler classifier (stage 3).
# Uses Claude Opus 4.7. Expect ~$0.50-$1.00 per video at default settings.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Where pipeline artifacts go. Each source video gets its own subdirectory
# named after the source's stem, so a file named `episode-12.mov` produces
# `<this dir>/episode-12/episode-12.analysis.json`, etc.
# Optional — defaults to `./files/` (project-relative) if unset. Set this to
# keep outputs on local disk while editing sources from an external drive, or
# to centralize outputs across many projects.
# CADENCE_OUTPUT_DIR=
